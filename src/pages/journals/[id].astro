---
import readableDate from "@components/readableDate";
import ReadableTypography from "@components/ReadableTypography.astro";
import Layout from "@layouts/Layout.astro";
import { getCollection, type CollectionEntry, render } from "astro:content";

export async function getStaticPaths() {
  const journalIndex = await getCollection("journalMetadata");
  const journalEntries = await getCollection("journalEntries");

  const journals = journalIndex.map((journalMetadata) => {
    const entries = journalEntries.filter(
      (entry) => entry.data.parent === journalMetadata.id,
    );
    return [journalMetadata, entries];
  });

  return journals.map(([metadata, entries]) => ({
    params: { id: metadata.id },
    props: { metadata, entries },
  }));
}

interface Props {
  metadata: CollectionEntry<"journalMetadata">;
  entries: CollectionEntry<"journalEntries">[];
}

const { metadata, entries } = Astro.props as Props;
const { name, description } = metadata.data;
---

<Layout title={name}>
  <div class="layout">
    <div class="intro">
      <h1 transition:name={`journal-title-${metadata.id}`}>{name}</h1>
      <ReadableTypography>
        <p>{description}</p>
      </ReadableTypography>
    </div>

    <aside>
      <p><b>Dates</b></p>
      {
        entries.map((entry, i) => (
          <a href={`#${entry.data.issue}`}>{readableDate(entry.data.date)}</a>
        ))
      }
    </aside>

    <hr />

    <main>
      <ReadableTypography>
        {
          entries.map(async (entry) => {
            const { id, data } = entry;
            const { title, date, issue } = data;
            const { Content } = await render(entry);
            return (
              <div class="journal-entry card" id={issue}>
                <h2>{title}</h2>
                <p class="date">{readableDate(date)}</p>
                <Content />
              </div>
            );
          })
        }
      </ReadableTypography>
    </main>
  </div>
</Layout>

<style>
  .layout {
    padding: 1rem 2rem;

    display: grid;
    row-gap: 2rem;
    column-gap: 2rem;
    grid-template-areas:
      "intro     intro         intro"
      "toc       hr            entries";
  }

  .intro {
    grid-area: intro;
  }

  aside {
    grid-area: toc;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;

    font-size: 1.3rem;

    position: sticky;
    top: 1rem;
    height: fit-content;

    a {
        display: block;
        
        font-family: var(--font-sans);
        text-decoration: none;
        color: var(--dark-color);
        padding: 0.5rem 0.5rem;

        border-radius: var(--rounded-corner-radius);

        transition: background-color 100ms ease-in-out;        

        &:hover, &.current {
          background-color: var(--surface-color);
        }
    }
  }

  hr {
    grid-area: hr;
    width: 1px;
    background-color: var(--dark-color);
    border: none;
    opacity: 0.5;
  }

  main {
    grid-area: entries;

    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  :global(.journal-entry img) {
    max-height: 400px;
    width: auto;
    border-radius: var(--rounded-corner-radius);
  }
</style>
