---
import "../../styles/typography.css";
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import ProjectPlatformChip from "../../components/projects/ProjectPlatformChip.astro";
import Header from "../../components/Header.astro";
import { render } from "astro:content";
import ProjectShowcaseImages from "../../components/projects/ProjectShowcaseImages.svelte";
import loadContentImage from "../../components/contentImage/loadContentImage";
import ToolChip from "../../components/ToolChip.astro";

export const getStaticPaths = (async () => {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}) satisfies GetStaticPaths;

const { project } = Astro.props;
const { id, data } = project;
const { title, description, tools, links, icon } = data;

const Icon = icon ? loadContentImage(icon) : undefined;
const showcaseImages = data.showcaseImages.map(
  (imagePath) => loadContentImage(imagePath).rasterMetadata.src,
);
const ProjectDetails = (await render(project)).Content;
---

<Layout>
  <Header />
  <main>
    <h1>
      {Icon ? <Icon.svgComponent /> : ""}
      {title}
    </h1>

    <div class="links">
      {
        links.map((link) => (
          <ProjectPlatformChip platform={link.platform} url={link.url} />
        ))
      }
    </div>

    <ProjectShowcaseImages images={showcaseImages} client:load />

    <div class="readable-typography">
      <div class="tools">
        <b>Tools used:</b>
        {tools.map((tool) => <ToolChip toolName={tool} style="chip" />)}
      </div>

      <ProjectDetails />
    </div>
  </main>
</Layout>

<style>
  main {
    padding-bottom: 1rem;
  }

  h1 {
    & :global(svg) {
      height: 0.9em;
      width: auto;
      vertical-align: baseline;
      margin-right: 0.4ch;
    }
  }

  .links {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .tools {
    display: inline-flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    align-items: center;
  }

  @media (min-width: 768px) {
    main {
      padding-inline: 2rem;
    }
  }
  @media (max-width: 767px) {
    main {
      padding-inline: 1rem;
    }
  }
</style>
