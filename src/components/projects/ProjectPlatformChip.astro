---
import { getEntry } from 'astro:content';

import loadContentImage from '../contentImage/loadContentImage';

interface Props {
  platform: string;
  url: string;
}

const { platform, url } = Astro.props;
const { name, color, icon } = (await getEntry('platforms', platform))!.data;

const Icon = loadContentImage(icon).svgComponent;
---

<a href={url}>
  <Icon />
  {name}
</a>

<style define:vars={{ platformColor: color, /* iconAspectRatio */ }}>
  a{
    --content-size: 1.5rem;
    
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.8rem;
    
    background-color: var(--platformColor);
    border-radius: 0.5rem;

    color: white !important;
    font-size: var(--content-size);
    text-decoration: none !important;
    word-break: keep-all;
  }

  a :global(svg) {
    /* aspect-ratio: var(--iconAspectRatio); */
    height: calc(var(--content-size) + 0.2rem);
  }
</style>
