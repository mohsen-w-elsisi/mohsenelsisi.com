---
import type { CollectionEntry } from "astro:content";
import ContentImageWidget from "../contentImage/ContentImageWidget.astro";
import ToolChip from "./ToolChip.astro";

interface Props {
  project: CollectionEntry<"projects">;
}

const { id, data } = Astro.props.project;
const { title, description, thumbnail, tools } = data;
---

<a href=`/projects/${id}` class="card project-card">
  <h3 transition:name={`project-title-${id}`}>
    <span>{title}</span>
  </h3>

  <ContentImageWidget
    transition:name=`project-thumbnail-${id}`
    transition:animate="slide"
    src={thumbnail}
    title={title}
    alt={`${title} thumbnail`}
  />

  <p>{description}</p>

  <div class="project-tool-icons">
    {tools.map((toolName) => <ToolChip toolName={toolName} style="icon" />)}
  </div>
</a>

<style>
  .project-card {
    display: grid;
    row-gap: 0.5rem;
    grid-template-rows:
      max-content /* title */
      1fr /* image */
      3lh /* description */
      24px /* tool icons */;
    overflow: visible;
  }

  .project-card > :global(.content-image) {
    width: 100%;
    height: 100%;
    overflow: hidden;

    object-fit: cover;
    border-radius: 10px;
  }

  h3 {
    font: var(--card-title-font);
    text-align: center;

    height: min-content;
    width: 100%;
    margin: auto 0;
    -webktit-line-clamp: 2;
  }

  p {
    font: var(--card-body-font);
  }

  .project-tool-icons {
    width: 100%;

    display: flex;
    gap: 0.5rem;
    justify-content: end;
  }
</style>
