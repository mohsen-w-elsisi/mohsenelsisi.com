---
import type { CollectionEntry } from "astro:content";
import JournalCard from "./JournalCard.astro";

interface Props {
  journals: CollectionEntry<"journalMetadata">[];
}

const { journals, ...props } = Astro.props as Props;
---

<ol {...props}>
  {journals.map((journal) => <JournalCard journal={journal} />)}
</ol>

<style>
  ol {
    width: 100%;
    margin: auto;
    align-self: center;

    display: grid;
    justify-items: stretch;
    align-items: stretch;
    gap: 1rem;

    list-style: none;
    padding: 0;
  }

  @media (max-width: 1060px) {
    ol {
      grid-template-columns: 1fr;
      max-width: 45rem;
    }
  }

  @media (min-width: 1061px) {
    ol {
      grid-template-columns: 1fr 1fr;
      max-width: 75rem;
    }
  }
</style>
